# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL (used for auth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encryption secret for OpenRouter API keys (AES-256-GCM, server-side only)
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters. Never expose this value publicly.
ENCRYPTION_SECRET=

# Encryption key for conversation message content at rest (AES-256-GCM, server-side only)
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters. Never expose this value publicly.
# If lost, all encrypted conversation history becomes unrecoverable.
MESSAGE_ENCRYPTION_KEY=